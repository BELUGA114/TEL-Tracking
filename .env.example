# Space-Track 账号配置示例
# 复制此文件为 .env 并填写真实凭据

SPACETRACK_USER=your_email@example.com
SPACETRACK_PASS=your_password

# User-Agent 配置（可选）
# Space-Track 和 CelesTrak 不强制要求 User-Agent，但建议填写以标识应用身份
# 格式建议："项目名称/版本 (联系方式)"
# 例如："MySatTracker/1.0 (user@example.com)"
# 留空则不发送 User-Agent 头部
CELESTRAK_USER_AGENT=
